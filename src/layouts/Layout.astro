---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingButton from "../components/FloatingButton.astro";
import BubbleBackground from "../components/BubbleBackground.astro";
import BubblePopScript from "../components/BubblePopScript.astro";
import logoImg from "../assets/brand/logo.png";
import { SITE_NAME, SITE_DESCRIPTION } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE_NAME, description = SITE_DESCRIPTION } = Astro.props;

const showFloatingButton = !Astro.url.pathname
  .replace(/\/$/, "")
  .endsWith("/support");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={logoImg.src} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=BIZ+UDPGothic:wght@400;700&family=Klee+One:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="flex min-h-screen flex-col overflow-x-hidden">
    <Header />

    <main class="grow relative">
      <BubbleBackground />
      <slot />
    </main>

    <Footer />

    {showFloatingButton && <FloatingButton />}

    <BubblePopScript />
  </body>
</html>
