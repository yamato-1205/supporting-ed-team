---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingButton from "../components/FloatingButton.astro";
import BubbleBackground from "../components/BubbleBackground.astro";
import BubblePopScript from "../components/BubblePopScript.astro";
import logoImg from "../assets/brand/logo.png";
import {
  SITE_NAME,
  SITE_DESCRIPTION,
  SITE_URL,
  OG_IMAGE_URL,
  CONTACT_EMAIL,
  THEME_COLOR,
  TWITTER_SITE,
  ORGANIZATION_SAME_AS,
  absoluteUrl,
  type BreadcrumbItem,
} from "../data/site";
import type { BubbleBackgroundDensity } from "../data/bubbles";

interface Props {
  /** ページ固有の <title> / og:title（未指定時は SITE_NAME） */
  title?: string;
  /** ページ固有の meta description（未指定時は SITE_DESCRIPTION） */
  description?: string;
  /** true のとき検索エンジンにインデックスさせない（直リンク限定ページ用） */
  noindex?: boolean;
  /** パンくず（JSON-LD BreadcrumbList）。TOP は自動で先頭に付与しないので必要なら含める */
  breadcrumbs?: BreadcrumbItem[];
  /**
   * 背景シャボン玉の密度。
   * 縦が短いページ（404 など）は sparse にして窮屈さを避ける。
   */
  bubbleDensity?: BubbleBackgroundDensity;
}

const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
  noindex = false,
  breadcrumbs,
  bubbleDensity = "default",
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const canonicalUrl = absoluteUrl(pathname === "/" ? "/" : `${pathname}/`);
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const showFloatingButton = !pathname.endsWith("/support");

const graph: Record<string, unknown>[] = [
  {
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    url: SITE_URL,
    name: SITE_NAME,
    description: SITE_DESCRIPTION,
    inLanguage: "ja",
    publisher: { "@id": `${SITE_URL}/#organization` },
  },
  {
    "@type": "NGO",
    "@id": `${SITE_URL}/#organization`,
    name: "さぽちむ",
    alternateName: ["Supporting/ed TEAM", SITE_NAME],
    url: SITE_URL,
    description: SITE_DESCRIPTION,
    email: CONTACT_EMAIL,
    logo: absoluteUrl(logoImg.src),
    image: OG_IMAGE_URL,
    inLanguage: "ja",
    sameAs: ORGANIZATION_SAME_AS,
    areaServed: {
      "@type": "Country",
      name: "日本",
    },
  },
  {
    "@type": "WebPage",
    "@id": `${canonicalUrl}#webpage`,
    url: canonicalUrl,
    name: title,
    description,
    isPartOf: { "@id": `${SITE_URL}/#website` },
    about: { "@id": `${SITE_URL}/#organization` },
    inLanguage: "ja",
  },
];

if (breadcrumbs && breadcrumbs.length > 0) {
  graph.push({
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: breadcrumbs.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      item: absoluteUrl(item.path),
    })),
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={THEME_COLOR} />

    {/* ファビコン・アプリアイコン（全ページ共通） */}
    <link rel="icon" type="image/png" href={logoImg.src} />
    <link rel="apple-touch-icon" href={logoImg.src} />

    {/* 基本 SEO（title / description はページごと、OG 画像は共通） */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />

    {/* 日本語向け */}
    <meta http-equiv="content-language" content="ja" />
    <link rel="alternate" hreflang="ja" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={absoluteUrl("/")} />

    {/* Open Graph（URL 貼り付け時のプレビュー） */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={OG_IMAGE_URL} />
    <meta property="og:image:alt" content={SITE_NAME} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    {/* X (Twitter) カード */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_SITE} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE_URL} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=BIZ+UDPGothic:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="flex min-h-screen flex-col overflow-x-hidden">
    <Header />

    <main class="grow relative">
      <BubbleBackground density={bubbleDensity} />
      <slot />
    </main>

    <Footer />

    {showFloatingButton && <FloatingButton />}

    <BubblePopScript />
  </body>
</html>
