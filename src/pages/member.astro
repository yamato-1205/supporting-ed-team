---
import Layout from "../layouts/Layout.astro";
import BubbleButton from "../components/BubbleButton.astro";
import RecruitTable from "../components/RecruitTable.astro";
import MemberCard from "../components/MemberCard.astro";
import MultilineText from "../components/MultilineText.astro";
import PageTitle from "../components/PageTitle.astro";
import { client } from "../lib/microcms";
import type { Member } from "../lib/microcms";
import { RECRUIT_TEAMS } from "../data/recruit";
import { MEMBER_PAGE } from "../data/member";
import { PAGE_META, SITE_NAME } from "../data/site";

let members: Member[] = [];
try {
  const res = await client.getList<Member>({
    endpoint: "member",
    queries: { limit: 100 },
  });
  members = res.contents;
} catch (e) {
  console.warn("[member] メンバー一覧の取得に失敗しました:", e);
}

const meta = PAGE_META.member;
---

<Layout
  title={meta.title}
  description={meta.description}
  breadcrumbs={[
    { name: SITE_NAME, path: "/" },
    { name: "メンバー募集", path: "/member/" },
  ]}
>
  <div
    id="member"
    class="relative z-10 pt-[calc(var(--header-height)+2rem)] pb-12 md:pt-[calc(var(--header-height)+2.5rem)] md:pb-16"
  >
    <div class="section-container flex flex-col gap-10 md:gap-14">
      <PageTitle title={MEMBER_PAGE.title} />

      <section
        class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
      >
        <h2 class="heading-2 mb-5">{MEMBER_PAGE.aboutTitle}</h2>
        <div class="space-y-4">
          {
            MEMBER_PAGE.aboutParagraphs.map((paragraph) => (
              <MultilineText text={paragraph} />
            ))
          }
          <ul class="space-y-1">
            {
              MEMBER_PAGE.aboutList.map((item) => (
                <li>・{item}</li>
              ))
            }
          </ul>
        </div>

        <img
          src={MEMBER_PAGE.diagram.src.src}
          alt={MEMBER_PAGE.diagram.alt}
          class="w-full max-w-2xl mx-auto mt-8"
        />
      </section>

      <div class="flex justify-center">
        <BubbleButton
          href={MEMBER_PAGE.contactHref}
          label={MEMBER_PAGE.contactLabel}
        />
      </div>

      <div class="flex flex-col gap-8 md:gap-10">
        {RECRUIT_TEAMS.map((team) => <RecruitTable team={team} />)}
      </div>

      <div class="flex justify-center">
        <BubbleButton
          href={MEMBER_PAGE.contactHref}
          label={MEMBER_PAGE.contactLabel}
        />
      </div>

      <section
        class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
      >
        <h2 class="heading-2 mb-6">{MEMBER_PAGE.membersTitle}</h2>
        {
          members.length === 0 ? (
            <p class="text-gray-500 text-center py-8">
              {MEMBER_PAGE.membersEmpty}
            </p>
          ) : (
            <div class="grid grid-cols-2 gap-x-4 gap-y-6 md:grid-cols-3 md:gap-x-6 md:gap-y-8">
              {members.map((m) => (
                <MemberCard name={m.name} iconUrl={m.icon.url} roll={m.roll} />
              ))}
            </div>
          )
        }
      </section>
    </div>
  </div>
</Layout>
