---
import Layout from "../layouts/Layout.astro";
import MultilineText from "../components/MultilineText.astro";
import PlacesMapSection from "../components/places/PlacesMapSection.astro";
import PlacesTagSection from "../components/places/PlacesTagSection.astro";
import PlacesResults from "../components/places/PlacesResults.astro";
import PlacesGoogleSection from "../components/places/PlacesGoogleSection.astro";
import PlacesFilterScript from "../components/places/PlacesFilterScript.astro";
import { client } from "../lib/microcms";
import type { Location } from "../lib/microcms";
import { PLACES_PAGE, countByPrefecture } from "../data/places";
import bubbleWide from "../assets/bubbles/bubble-wide.png";
import { PAGE_META } from "../data/site";

let locations: Location[] = [];
try {
  const res = await client.getList<Location>({
    endpoint: "location",
    queries: { limit: 100 },
  });
  locations = res.contents;
} catch (e) {
  console.warn("[places] 居場所一覧の取得に失敗しました:", e);
}

const prefCount = countByPrefecture(locations).size;
const meta = PAGE_META.places;
---

<Layout noindex title={meta.title} description={meta.description}>
  <div
    id="places"
    class="relative z-10 pt-[calc(var(--header-height)+2rem)] pb-12 md:pt-[calc(var(--header-height)+2.5rem)] md:pb-16"
  >
    <div class="section-container flex flex-col gap-8 md:gap-10">
      <header class="text-center">
        <h1 class="heading-2">{PLACES_PAGE.title}</h1>
        <p class="mt-3 font-normal tracking-wide text-[var(--color-primary)]">
          {PLACES_PAGE.lead}
        </p>
        <MultilineText
          text={PLACES_PAGE.intro}
          class="mx-auto mt-4 max-w-2xl font-normal leading-relaxed text-black/75"
        />
      </header>

      <div class="grid grid-cols-2 gap-3 sm:mx-auto sm:max-w-md">
        <div
          class="relative flex flex-col items-center justify-center px-2 py-4 text-center"
        >
          <img
            src={bubbleWide.src}
            alt=""
            aria-hidden="true"
            class="absolute inset-0 m-auto h-20 w-auto opacity-90 sm:h-24"
          />
          <p class="relative text-2xl font-bold text-[var(--color-primary)] sm:text-3xl">
            {prefCount}
          </p>
          <p class="relative text-small font-normal">{PLACES_PAGE.statsPrefLabel}</p>
        </div>
        <div
          class="relative flex flex-col items-center justify-center px-2 py-4 text-center"
        >
          <img
            src={bubbleWide.src}
            alt=""
            aria-hidden="true"
            class="absolute inset-0 m-auto h-20 w-auto opacity-90 sm:h-24"
          />
          <p class="relative text-2xl font-bold text-[var(--color-primary)] sm:text-3xl">
            {locations.length}
          </p>
          <p class="relative text-small font-normal">{PLACES_PAGE.statsCountLabel}</p>
        </div>
      </div>

      <PlacesMapSection locations={locations} />
      <PlacesTagSection locations={locations} />
      <PlacesResults locations={locations} />
      <PlacesGoogleSection locations={locations} />
    </div>
  </div>
  <PlacesFilterScript />
</Layout>
