---
import {
  BACKGROUND_BUBBLES,
  type BubbleBackgroundDensity,
} from "../data/bubbles";

interface Props {
  /** 縦が短いページは sparse（デフォルトは default） */
  density?: BubbleBackgroundDensity;
}

const { density = "default" } = Astro.props;
const bubbles = BACKGROUND_BUBBLES[density];
---

<div
  id="bubble-background"
  class="absolute inset-0 z-0 overflow-hidden pointer-events-none select-none"
  data-density={density}
  aria-hidden="true"
>
  {
    bubbles.map((bubble) => (
      <img
        src={bubble.src.src}
        alt=""
        class={`bubble-float absolute ${bubble.class}`}
        draggable="false"
      />
    ))
  }
</div>
