---
import BubbleButton from "./BubbleButton.astro";
import SectionBubbles from "./SectionBubbles.astro";
import RibbonDate from "./RibbonDate.astro";
import frameImg from "../assets/decorations/results-frame.png";
import reportCardImg from "../assets/decorations/news-card.png";
import { fetchNoteArticles, stripHtml } from "../lib/note";
import { splitDate } from "../lib/date";
import { client } from "../lib/microcms";
import type { ExternalReport } from "../lib/microcms";
import { NOTE_ACCOUNT } from "../data/site";

const noteHref = `https://note.com/${NOTE_ACCOUNT}`;
const items = await fetchNoteArticles(NOTE_ACCOUNT, 10);

let exReports: ExternalReport[] = [];
try {
  const res = await client.getList<ExternalReport>({
    endpoint: "ex_report",
    queries: { orders: "-date", limit: 20 },
  });
  exReports = res.contents;
} catch (e) {
  console.warn("[ActivityResultSection] 外部レポートの取得に失敗しました:", e);
}
---

<section
  id="results"
  class="relative z-[1] overflow-x-clip bg-[var(--color-background)] py-7 md:py-10"
>
  <SectionBubbles variant="results" />

  <div class="section-container">
    <h2 class="heading-2 mb-6">活動実績</h2>

    <h3 class="heading-3 mb-8">内部レポート</h3>

    {
      items.length === 0 ? (
        <p class="text-gray-500 text-center py-8">現在活動実績はありません。</p>
      ) : (
        <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory -mx-2 px-2 md:-mx-8 md:px-8">
          {items.map((item) => {
            const { year, monthDay } = splitDate(item.pubDate);
            const plainDesc = stripHtml(item.description);
            return (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="snap-start shrink-0 relative block w-[320px] md:w-[320px] hover:opacity-85 transition-opacity"
                aria-label={item.title}
              >
                <img
                  src={frameImg.src}
                  alt=""
                  aria-hidden="true"
                  class="w-full h-auto block"
                />

                <div class="absolute inset-0 z-10 px-3.5 flex flex-col overflow-hidden">
                  <div class="relative shrink-0">
                    {item.thumbnail && (
                      <img
                        src={item.thumbnail}
                        alt=""
                        aria-hidden="true"
                        class="w-[291px] h-[167px] object-cover block"
                        style="margin-top: 44px;"
                      />
                    )}
                    <RibbonDate
                      year={year}
                      monthDay={monthDay}
                      wrapperClass="absolute top-0 left-0 z-20"
                      ribbonClass="h-18 w-14 block"
                    />
                  </div>

                  <div class="flex-1 min-h-0 overflow-hidden flex flex-col">
                    <div
                      class="shrink-0 overflow-hidden pt-2 pb-1"
                      style="max-height: calc(2 * 1.375rem + 0.5rem + 0.25rem);"
                    >
                      <p class="font-bold leading-snug line-clamp-2">
                        {item.title}
                      </p>
                    </div>

                    <div
                      class="overflow-hidden pb-2"
                      style="max-height: calc(4 * 1.375rem + 0.5rem);"
                    >
                      <p class="leading-snug line-clamp-4 text-gray-700">
                        {plainDesc}
                      </p>
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      )
    }

    <div class="mt-10 flex justify-center">
      <BubbleButton href={noteHref} label="もっと見る ↗" external />
    </div>

    <h3 class="heading-3 mt-14 mb-8">外部レポート</h3>

    {
      exReports.length === 0 ? (
        <p class="text-gray-500 text-center py-8">
          現在外部レポートはありません。
        </p>
      ) : (
        <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory -mx-2 px-2 md:-mx-8 md:px-8">
          {exReports.map((report) => {
            const { year, monthDay } = splitDate(report.date);
            return (
              <a
                href={report.link}
                target="_blank"
                rel="noopener noreferrer"
                class="snap-start shrink-0 relative block w-[290px] hover:opacity-85 transition-opacity"
                aria-label={report.title}
              >
                <img
                  src={reportCardImg.src}
                  alt=""
                  aria-hidden="true"
                  class="w-full h-auto block"
                />

                <div class="absolute inset-0 z-10 px-3 py-0 overflow-hidden flex flex-col">
                  <div class="relative">
                    <RibbonDate
                      year={year}
                      monthDay={monthDay}
                      wrapperClass="absolute top-0 left-0 z-20"
                      ribbonClass="h-18 w-14 block"
                    />
                    <p class="ml-14 py-3.5 leading-snug line-clamp-2 text-gray-700">
                      {report.media.join("・")}
                    </p>
                  </div>
                  <p class="font-bold px-1 leading-snug line-clamp-2">
                    {report.title}
                  </p>
                </div>
              </a>
            );
          })}
        </div>
      )
    }
  </div>
</section>
