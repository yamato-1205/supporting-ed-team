---
import BubbleButton from "./BubbleButton.astro";
import MultilineText from "./MultilineText.astro";
import { MEMBER_RECRUIT_CTA } from "../data/home";
---

<section id="member" class="py-5 md:py-8">
  <div class="max-w-[1280px] mx-auto px-4 md:px-6">
    <div
      class="rounded-3xl bg-[#cde9f7] flex flex-col md:flex-row overflow-hidden md:min-h-[260px]"
    >
      <div
        class="flex-1 flex flex-col justify-between px-8 py-6 md:px-10 md:py-6"
      >
        <div>
          <h2 class="heading-3 mb-3">{MEMBER_RECRUIT_CTA.title}</h2>
          <MultilineText
            text={MEMBER_RECRUIT_CTA.headline}
            class="heading-2 leading-tight"
          />
          <p class="mt-2">{MEMBER_RECRUIT_CTA.body}</p>
        </div>

        <div>
          <BubbleButton
            href={MEMBER_RECRUIT_CTA.href}
            label={MEMBER_RECRUIT_CTA.buttonLabel}
          />
        </div>
      </div>

      <div class="md:w-[42%] shrink-0 flex flex-row h-44 md:h-auto">
        {
          MEMBER_RECRUIT_CTA.images.map((image) => (
            <div class="flex-1 overflow-hidden">
              <img
                src={image.src.src}
                alt={image.alt}
                class="w-full h-full object-cover"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
