---
import BubbleButton from "./BubbleButton.astro";
import eventImg from "../assets/活動内容_イベント.jpg";
import communityImg from "../assets/活動内容_コミュニティ.jpg";
---

<section id="member" class="py-10 md:py-16">
  <div class="max-w-[1280px] mx-auto px-4 md:px-6">
    <div
      class="rounded-3xl bg-[#cde9f7] flex flex-col md:flex-row overflow-hidden md:min-h-[260px]"
    >
      <!-- ── 左：テキスト ── -->
      <div
        class="flex-1 flex flex-col justify-between px-8 py-6 md:px-10 md:py-6"
      >
        <div>
          <h2 class="section-heading mb-3">新規メンバー募集</h2>
          <p
            class="text-xl md:text-2xl font-bold leading-tight"
            style="font-family: var(--font-hand);"
          >
            おもしろそう、やってみたい…<br />
            やっちゃおう！
          </p>
          <p class="mt-2 leading-relaxed">
            本気で遊びながらイベントを作るチームに参加してみませんか？
          </p>
        </div>

        <div>
          <BubbleButton href="/member" label="詳しく見る" />
        </div>
      </div>

      <!-- ── 右：2枚を均等に横並び ── -->
      <div class="md:w-[42%] shrink-0 flex flex-row h-44 md:h-auto">
        <div class="flex-1 overflow-hidden">
          <img
            src={communityImg.src}
            alt="コミュニティの様子"
            class="w-full h-full object-cover"
          />
        </div>

        <div class="flex-1 overflow-hidden">
          <img
            src={eventImg.src}
            alt="イベントの様子"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
