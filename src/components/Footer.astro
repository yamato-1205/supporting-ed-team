---
import bannerImg from "../assets/brand/banner.png";
import footerWave from "../assets/decorations/footer-wave.png";
import cityscapeImg from "../assets/decorations/cityscape.png";
import houseSquare from "../assets/decorations/house.png";
import houseWide from "../assets/decorations/house-wide.png";
import SnsButton from "./SnsButton.astro";
import { getSnsLinks } from "../data/sns";
import { NAV_GROUPS } from "../data/navigation";
import { CONTACT_EMAIL, COPYRIGHT_YEAR } from "../data/site";

const snsLinks = getSnsLinks("footer");
---

<footer id="contact" class="relative overflow-hidden bg-[var(--color-primary)]">
  <img
    src={footerWave.src}
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 z-0 w-full h-auto -translate-y-[15%] select-none"
  />

  <div
    class="relative z-10 mx-auto max-w-[1280px] px-6 pt-24 md:px-10 lg:px-16 md:pt-32"
  >
    <div class="mb-8 md:mb-10">
      <a href="/" class="mb-2 inline-block">
        <img
          src={bannerImg.src}
          alt="さぽちむ Supporting/ed TEAM"
          class="h-10 w-auto rounded"
        />
      </a>
      <p class="tracking-wide text-white/90">
        メール：<a href={`mailto:${CONTACT_EMAIL}`} class="hover:underline"
          >{CONTACT_EMAIL}</a
        >
      </p>
    </div>

    <nav
      aria-label="フッターナビゲーション"
      class="mb-10 flex w-fit max-w-full flex-col gap-6 text-left sm:flex-row sm:flex-wrap sm:gap-x-10 sm:gap-y-6 md:mb-12 md:gap-x-12 lg:gap-x-14"
    >
      {
        NAV_GROUPS.map((group) => (
          <div class="min-w-0 shrink-0">
            <a
              href={group.href}
              class="mb-2.5 inline-block text-lg font-bold tracking-wide text-white transition-colors hover:text-white/80"
            >
              {group.label}
            </a>
            <ul class="space-y-2 border-l border-white/30 pl-3">
              {group.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="tracking-wide text-white/85 transition-colors hover:text-white"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>

    <div class="mb-3 flex items-end justify-between gap-3">
      <div
        class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:flex md:flex-wrap md:items-center md:gap-2"
      >
        {
          snsLinks.map((sns) => (
            <SnsButton
              href={sns.href}
              icon={sns.icon.src}
              label={sns.label}
              isX={sns.id === "x"}
              bgSrc={houseSquare.src}
              invert={sns.id === "note"}
              iconShiftClass="translate-y-[18%]"
              sizeClass="h-16 w-auto"
            />
          ))
        }
      </div>

      <a
        href="/contact"
        aria-label="お問い合わせ"
        class="btn-hover relative block shrink-0"
      >
        <img
          src={houseWide.src}
          alt=""
          aria-hidden="true"
          class="block h-16 w-auto"
        />
        <span
          class="absolute inset-x-0 bottom-[28%] text-center text-[0.7rem] leading-tight tracking-wide text-white"
        >
          お問い合わせ
        </span>
      </a>
    </div>
  </div>

  <div
    class="relative z-10 h-14 w-full bg-repeat-x md:h-16"
    aria-hidden="true"
    style={`background-image: url(${cityscapeImg.src}); background-size: auto 100%; background-position: left bottom;`}
  >
  </div>

  <p class="relative z-10 pb-4 pt-1 text-center text-small text-white/70">
    © さぽちむ {COPYRIGHT_YEAR}
  </p>
</footer>
