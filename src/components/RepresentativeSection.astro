---
import SnsButton from "./SnsButton.astro";
import SectionBubbles from "./SectionBubbles.astro";
import MultilineText from "./MultilineText.astro";
import { bubble1, bubble2, bubble3, bubble4 } from "../data/bubbles";
import { getSnsLinks } from "../data/sns";
import { REPRESENTATIVE } from "../data/home";

const snsLinks = getSnsLinks("representative");
---

<section
  id="about"
  class="relative z-[1] overflow-x-clip bg-[var(--color-background)] py-8 md:py-12"
>
  <SectionBubbles variant="representative" />

  <div class="section-container">
    <h2 class="heading-2 mb-32">代表の思い</h2>

    <div class="relative">
      <div class="absolute -top-24 left-1/2 z-30 h-36 w-36 -translate-x-1/2">
        <div class="relative h-full w-full">
          <img
            src={REPRESENTATIVE.image.src}
            alt={REPRESENTATIVE.imageAlt}
            class="h-full w-full rounded-full object-cover"
          />
          <img
            src={bubble1.src}
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 h-full w-full select-none rounded-full object-cover"
            style="mix-blend-mode: overlay; opacity: 0.65;"
          />

          <img
            src={bubble3.src}
            alt=""
            aria-hidden="true"
            class="bubble-float pointer-events-none absolute h-8 w-8 select-none opacity-80 max-md:hidden"
            style="bottom: 2px; left: -18px;"
          />
          <img
            src={bubble4.src}
            alt=""
            aria-hidden="true"
            class="bubble-float pointer-events-none absolute h-5 w-5 select-none opacity-70 max-md:hidden"
            style="bottom: 20px; left: -34px;"
          />
          <img
            src={bubble2.src}
            alt=""
            aria-hidden="true"
            class="bubble-float pointer-events-none absolute hidden h-10 w-10 select-none opacity-75 md:block"
            style="bottom: 0px; right: -24px;"
          />
          <img
            src={bubble3.src}
            alt=""
            aria-hidden="true"
            class="bubble-float pointer-events-none absolute hidden h-5 w-5 select-none opacity-65 md:block"
            style="bottom: 22px; right: -40px;"
          />
        </div>
      </div>

      <div
        class="absolute top-[-1.5rem] left-1/2 z-30 ml-[calc(4.5rem+0.35rem)] flex -translate-y-1/2 flex-col gap-1 md:hidden"
      >
        {
          snsLinks.map((sns) => (
            <SnsButton
              href={sns.href}
              icon={sns.icon.src}
              label={sns.label}
              isX={sns.id === "x"}
              sizeClass="h-10 w-auto"
            />
          ))
        }
      </div>

      <div class="relative overflow-hidden rounded-2xl bg-white">
        <div class="absolute top-3 right-3 z-10 hidden items-center md:flex">
          <span class="mr-2 flex gap-1.5 opacity-40" aria-hidden="true">
            <span
              class="border-y-[7px] border-y-transparent border-l-[11px] border-l-gray-500"
            ></span>
            <span
              class="border-y-[7px] border-y-transparent border-l-[11px] border-l-gray-500"
            ></span>
            <span
              class="border-y-[7px] border-y-transparent border-l-[11px] border-l-gray-500"
            ></span>
          </span>
          {
            snsLinks.map((sns) => (
              <SnsButton
                href={sns.href}
                icon={sns.icon.src}
                label={sns.label}
                isX={sns.id === "x"}
              />
            ))
          }
        </div>

        <div class="px-8 pt-16 pb-10 md:px-12">
          <p class="text-center mb-5">{REPRESENTATIVE.nameLabel}</p>

          <MultilineText text={REPRESENTATIVE.intro} class="mb-5" />

          {
            REPRESENTATIVE.folds.map((fold) => (
              <details class="about-fold mb-5 last:mb-0" data-about-fold>
                <summary class="about-fold-summary list-none">
                  <span class="heading-3 flex items-center justify-center gap-2 text-center">
                    {fold.title}
                    <span
                      class="about-fold-chevron text-sm font-normal text-[var(--color-primary)] transition-transform md:hidden"
                      aria-hidden="true"
                    >
                      ▼
                    </span>
                  </span>
                </summary>
                <MultilineText text={fold.body} class="mt-4" />
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-fold-summary {
    cursor: pointer;
  }
  .about-fold-summary::-webkit-details-marker {
    display: none;
  }
  .about-fold[open] .about-fold-chevron {
    transform: rotate(180deg);
  }
  @media (min-width: 768px) {
    .about-fold-summary {
      cursor: default;
      pointer-events: none;
    }
    .about-fold-chevron {
      display: none;
    }
  }
</style>

<script>
  function syncAboutFolds() {
    const isDesktop = window.matchMedia("(min-width: 768px)").matches;
    document
      .querySelectorAll<HTMLDetailsElement>("[data-about-fold]")
      .forEach((el) => {
        if (isDesktop) {
          el.open = true;
        } else if (!el.dataset.userToggled) {
          el.open = false;
        }
      });
  }

  function initAboutFolds() {
    document
      .querySelectorAll<HTMLDetailsElement>("[data-about-fold]")
      .forEach((el) => {
        if (el.dataset.foldInit) return;
        el.dataset.foldInit = "true";
        el.addEventListener("toggle", () => {
          if (!window.matchMedia("(min-width: 768px)").matches) {
            el.dataset.userToggled = "true";
          }
        });
      });
    syncAboutFolds();
  }

  initAboutFolds();
  window.addEventListener("resize", syncAboutFolds);
  document.addEventListener("astro:page-load", initAboutFolds);
</script>
