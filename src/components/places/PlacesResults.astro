---
import LocationCard from "./LocationCard.astro";
import { PLACES_PAGE, countByTag } from "../../data/places";
import type { Location } from "../../lib/microcms";

interface Props {
  locations: Location[];
}

const { locations } = Astro.props;
const fields = countByTag(locations, "field");
const genres = countByTag(locations, "genre");
---

<section
  id="place-results"
  class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
  aria-live="polite"
>
  <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap items-center gap-3">
      <h2 class="heading-3">{PLACES_PAGE.listTitle}</h2>
      <button
        type="button"
        class="place-clear-btn rounded-full border-2 border-[var(--color-primary)] bg-white px-3.5 py-1 text-small font-bold text-[var(--color-primary)] transition-colors hover:bg-[var(--color-primary)] hover:text-white"
        hidden
      >
        {PLACES_PAGE.clearFilter}
      </button>
    </div>
    <p class="text-small font-normal text-black/60">
      <span data-place-result-count>{locations.length}</span> 件表示中
    </p>
  </div>

  {
    (fields.size > 0 || genres.size > 0) && (
      <div class="mb-6 space-y-4">
        {fields.size > 0 && (
          <div>
            <p class="mb-2 text-small tracking-wide text-black/55">
              {PLACES_PAGE.fieldLabel}
            </p>
            <ul class="flex flex-wrap gap-2">
              {[...fields.entries()].map(([tag, count]) => (
                <li>
                  <button
                    type="button"
                    class="place-filter-chip rounded-full border border-[var(--color-primary)]/30 bg-white px-3.5 py-1.5 text-small font-bold text-black/80 transition-colors hover:border-[var(--color-primary)] aria-[pressed=true]:border-[var(--color-primary)] aria-[pressed=true]:bg-[var(--color-primary)] aria-[pressed=true]:text-white"
                    data-filter-type="tag"
                    data-filter-value={tag}
                    aria-pressed="false"
                  >
                    {tag}
                    <span class="ml-1 font-normal opacity-70">{count}</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>
        )}
        {genres.size > 0 && (
          <div>
            <p class="mb-2 text-small tracking-wide text-black/55">
              {PLACES_PAGE.genreLabel}
            </p>
            <ul class="flex flex-wrap gap-2">
              {[...genres.entries()].map(([tag, count]) => (
                <li>
                  <button
                    type="button"
                    class="place-filter-chip rounded-full border border-[var(--color-primary)]/30 bg-white px-3.5 py-1.5 text-small font-bold text-black/80 transition-colors hover:border-[var(--color-primary)] aria-[pressed=true]:border-[var(--color-primary)] aria-[pressed=true]:bg-[var(--color-primary)] aria-[pressed=true]:text-white"
                    data-filter-type="tag"
                    data-filter-value={tag}
                    aria-pressed="false"
                  >
                    {tag}
                    <span class="ml-1 font-normal opacity-70">{count}</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )
  }

  <div class="flex flex-col gap-3" data-place-list>
    {
      locations.map((loc) => (
        <LocationCard
          id={loc.id}
          name={loc.locationName}
          address={loc.address}
          prefectures={loc.prefectures}
          field={loc.field}
          genre={loc.genre}
          lat={loc.lat}
          lng={loc.lng}
        />
      ))
    }
  </div>
  <p
    class="place-empty mt-6 hidden text-center font-normal text-black/50"
    data-place-empty
  >
    {PLACES_PAGE.empty}
  </p>
</section>
