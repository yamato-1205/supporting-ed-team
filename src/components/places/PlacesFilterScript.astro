---
/**
 * 居場所マップの絞り込み・Google埋め込み切替。
 * 都道府県・タグは AND 条件で .place-card を出し分けする。
 */
---

<script>
  function parseJsonArray(value: string | null): string[] {
    if (!value) return [];
    try {
      const parsed = JSON.parse(value);
      return Array.isArray(parsed) ? parsed.map(String) : [];
    } catch {
      return [];
    }
  }

  function embedUrl(lat: number, lng: number, zoom = 15): string {
    return `https://maps.google.com/maps?q=${encodeURIComponent(`${lat},${lng}`)}&z=${zoom}&output=embed&hl=ja`;
  }

  function externalUrl(lat: number, lng: number, name: string): string {
    return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${name} ${lat},${lng}`)}`;
  }

  const cards = [...document.querySelectorAll<HTMLElement>(".place-card")];
  const prefButtons = [
    ...document.querySelectorAll<HTMLButtonElement>(".place-pref-btn"),
  ];
  const tagButtons = [
    ...document.querySelectorAll<HTMLButtonElement>(".place-tag-btn"),
  ];
  const clearButtons = [
    ...document.querySelectorAll<HTMLButtonElement>(".place-clear-btn"),
  ];
  const emptyEls = [
    ...document.querySelectorAll<HTMLElement>("[data-place-empty]"),
  ];
  const countEls = [
    ...document.querySelectorAll<HTMLElement>("[data-place-result-count]"),
  ];
  const pinButtons = [
    ...document.querySelectorAll<HTMLButtonElement>(".place-map-pin"),
  ];
  const iframe = document.getElementById(
    "place-google-embed",
  ) as HTMLIFrameElement | null;
  const externalLink = document.getElementById(
    "place-google-external",
  ) as HTMLAnchorElement | null;

  let activePrefecture: string | null = null;
  const activeTags = new Set<string>();

  function applyFilter() {
    let visible = 0;
    for (const card of cards) {
      const prefs = parseJsonArray(card.dataset.prefectures ?? null);
      const tags = parseJsonArray(card.dataset.tags ?? null);
      const prefOk =
        !activePrefecture || prefs.includes(activePrefecture);
      const tagsOk =
        activeTags.size === 0 ||
        [...activeTags].every((tag) => tags.includes(tag));
      const show = prefOk && tagsOk;
      card.hidden = !show;
      card.classList.toggle("opacity-40", false);
      if (show) visible += 1;
    }

    for (const el of countEls) el.textContent = String(visible);
    for (const el of emptyEls) el.classList.toggle("hidden", visible > 0);

    const filtering = Boolean(activePrefecture) || activeTags.size > 0;
    for (const btn of clearButtons) btn.hidden = !filtering;
  }

  function setPressed(btn: HTMLButtonElement, pressed: boolean) {
    btn.setAttribute("aria-pressed", pressed ? "true" : "false");
  }

  for (const btn of prefButtons) {
    btn.addEventListener("click", () => {
      const pref = btn.dataset.prefecture ?? null;
      const next = activePrefecture === pref ? null : pref;
      activePrefecture = next;
      for (const b of prefButtons) {
        setPressed(b, b.dataset.prefecture === next);
      }
      applyFilter();
    });
  }

  for (const btn of tagButtons) {
    btn.addEventListener("click", () => {
      const tag = btn.dataset.tag;
      if (!tag) return;
      if (activeTags.has(tag)) activeTags.delete(tag);
      else activeTags.add(tag);
      setPressed(btn, activeTags.has(tag));
      applyFilter();
    });
  }

  function clearFilters() {
    activePrefecture = null;
    activeTags.clear();
    for (const b of prefButtons) setPressed(b, false);
    for (const b of tagButtons) setPressed(b, false);
    applyFilter();
  }

  for (const btn of clearButtons) {
    btn.addEventListener("click", clearFilters);
  }

  for (const pin of pinButtons) {
    pin.addEventListener("click", () => {
      const lat = Number(pin.dataset.lat);
      const lng = Number(pin.dataset.lng);
      const name = pin.dataset.name ?? "";
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;

      for (const p of pinButtons) setPressed(p, p === pin);
      if (iframe) iframe.src = embedUrl(lat, lng);
      if (externalLink) {
        externalLink.href = externalUrl(lat, lng, name);
      }

      const id = pin.dataset.placeId;
      if (id) {
        const card = cards.find((c) => c.dataset.placeId === id);
        card?.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    });
  }

  applyFilter();
</script>
