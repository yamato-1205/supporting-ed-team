---
import { PLACES_PAGE, googleMapsEmbedUrl, googleMapsLink } from "../../data/places";

interface Props {
  id: string;
  name: string;
  address: string;
  prefectures: string[];
  field: string[];
  genre: string[];
  lat: number;
  lng: number;
}

const { id, name, address, prefectures, field, genre, lat, lng } = Astro.props;
const tags = [...field, ...genre];
const embedSrc = googleMapsEmbedUrl(lat, lng);
const mapsHref = googleMapsLink(address);
const panelId = `place-panel-${id}`;
---

<article
  class="place-card rounded-2xl border border-[var(--color-primary)]/20 bg-[var(--color-background)]/70 px-4 py-4 md:px-5 md:py-5"
  data-place-id={id}
  data-prefectures={JSON.stringify(prefectures)}
  data-tags={JSON.stringify(tags)}
  data-lat={lat}
  data-lng={lng}
  data-name={name}
>
  <div class="flex flex-col gap-3">
    <button
      type="button"
      class="place-banner-toggle flex w-full items-center justify-between gap-3 text-left"
      aria-expanded="false"
      aria-controls={panelId}
    >
      <span class="heading-3 min-w-0 leading-snug">{name}</span>
      <span
        class="inline-flex shrink-0 items-center gap-1 text-small font-bold text-[var(--color-primary)]"
      >
        <span class="place-banner-hint">{PLACES_PAGE.openMap}</span>
        <span class="place-banner-chevron transition-transform" aria-hidden="true">
          ▾
        </span>
      </span>
    </button>

    <div class="flex flex-wrap gap-1.5">
      {
        prefectures.map((pref) => (
          <button
            type="button"
            class="place-filter-chip rounded-full border border-[var(--color-primary)]/30 bg-white px-2.5 py-0.5 text-small font-bold text-black/80 transition-colors hover:border-[var(--color-primary)] aria-[pressed=true]:border-[var(--color-primary)] aria-[pressed=true]:bg-[var(--color-primary)] aria-[pressed=true]:text-white"
            data-filter-type="prefecture"
            data-filter-value={pref}
            aria-pressed="false"
          >
            {pref}
          </button>
        ))
      }
      {
        tags.map((tag) => (
          <button
            type="button"
            class="place-filter-chip rounded-full border border-[var(--color-primary)]/30 bg-white px-2.5 py-0.5 text-small font-normal text-black/80 transition-colors hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] aria-[pressed=true]:border-[var(--color-primary)] aria-[pressed=true]:bg-[var(--color-primary)] aria-[pressed=true]:text-white"
            data-filter-type="tag"
            data-filter-value={tag}
            aria-pressed="false"
          >
            {tag}
          </button>
        ))
      }
    </div>

    <div id={panelId} class="place-banner-panel hidden space-y-3" hidden>
      <p class="font-normal leading-relaxed text-black/75">{address}</p>
      <div
        class="overflow-hidden rounded-2xl border border-[var(--color-primary)]/15 bg-white"
      >
        <iframe
          class="place-banner-embed aspect-[4/3] w-full border-0 md:aspect-[16/11]"
          title={`${name}のGoogleマップ`}
          data-src={embedSrc}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
      <p class="text-center text-small font-normal text-black/60">
        <a
          href={mapsHref}
          target="_blank"
          rel="noopener noreferrer"
          class="font-bold text-[var(--color-primary)] underline-offset-2 hover:underline"
        >
          {PLACES_PAGE.openInGoogle}
        </a>
      </p>
    </div>
  </div>
</article>

<style>
  .place-card[data-open="true"] .place-banner-chevron {
    transform: rotate(180deg);
  }
</style>
