---
interface Props {
  id: string;
  name: string;
  address: string;
  prefectures: string[];
  field: string[];
  genre: string[];
  lat: number;
  lng: number;
}

const { id, name, address, prefectures, field, genre, lat, lng } = Astro.props;
const tags = [...field, ...genre];
---

<article
  class="place-card rounded-2xl border border-[var(--color-primary)]/20 bg-[var(--color-background)]/60 px-4 py-4 md:px-5 md:py-5 transition-opacity"
  data-place-id={id}
  data-prefectures={JSON.stringify(prefectures)}
  data-tags={JSON.stringify(tags)}
  data-lat={lat}
  data-lng={lng}
  data-name={name}
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="heading-3 leading-snug">{name}</h3>
    <span
      class="shrink-0 rounded-full bg-[var(--color-primary)]/15 px-2.5 py-0.5 text-small font-bold text-[var(--color-primary)]"
    >
      {prefectures.join("・") || "—"}
    </span>
  </div>
  <p class="mt-2 font-normal leading-relaxed text-black/75">{address}</p>
  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <li class="rounded-full border border-[var(--color-primary)]/30 bg-white px-2.5 py-0.5 text-small font-normal text-black/80">
            {tag}
          </li>
        ))}
      </ul>
    )
  }
</article>
