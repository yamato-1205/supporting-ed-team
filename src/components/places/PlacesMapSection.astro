---
import HeadingUnderline from "../HeadingUnderline.astro";
import { PLACES_PAGE, REGION_GROUPS, countByPrefecture } from "../../data/places";
import type { Location } from "../../lib/microcms";
import bubbleImg from "../../assets/bubbles/bubble-2.png";

interface Props {
  locations: Location[];
}

const { locations } = Astro.props;
const prefCounts = countByPrefecture(locations);
const regionsWithData = REGION_GROUPS.filter((region) =>
  region.prefectures.some((p) => (prefCounts.get(p) ?? 0) > 0),
);
---

<section
  id="map-search"
  class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
>
  <HeadingUnderline class="mb-3 md:mb-4">{PLACES_PAGE.mapTitle}</HeadingUnderline>
  <p class="mx-auto mb-6 max-w-2xl text-center font-normal leading-relaxed text-black/75">
    {PLACES_PAGE.mapLead}
  </p>

  <div
    class="relative mx-auto mb-8 max-w-3xl overflow-hidden rounded-2xl bg-[var(--color-background)]"
  >
    <img
      src={PLACES_PAGE.diagram.src}
      alt="日本地図（さぽちむ居場所マップ）"
      class="w-full opacity-90"
      width={PLACES_PAGE.diagram.width}
      height={PLACES_PAGE.diagram.height}
    />
    <p
      class="pointer-events-none absolute bottom-3 left-3 rounded-full bg-white/85 px-3 py-1 text-small font-normal text-black/70 backdrop-blur-sm md:bottom-4 md:left-4"
    >
      ※地図画像は仮素材です。後日差し替え予定
    </p>
  </div>

  <div class="space-y-6">
    {
      regionsWithData.map((region) => (
        <div>
          <p class="mb-2 text-small tracking-wide text-black/55">{region.name}</p>
          <div class="flex flex-wrap gap-2">
            {region.prefectures.map((pref) => {
              const count = prefCounts.get(pref) ?? 0;
              if (count === 0) {
                return (
                  <span
                    class="inline-flex min-w-[4.25rem] items-center justify-center rounded-full border border-black/10 px-3 py-2 text-small font-normal text-black/30"
                    title="まだ掲載がありません"
                  >
                    {pref.replace(/[都道府県]$/, "")}
                  </span>
                );
              }
              return (
                <button
                  type="button"
                  class="place-pref-btn group relative inline-flex min-w-[4.5rem] items-center justify-center px-1 py-1"
                  data-prefecture={pref}
                  aria-pressed="false"
                >
                  <img
                    src={bubbleImg.src}
                    alt=""
                    aria-hidden="true"
                    class="h-12 w-auto opacity-90 transition-transform group-hover:scale-105 group-aria-[pressed=true]:scale-110"
                  />
                  <span class="absolute inset-0 flex flex-col items-center justify-center leading-tight">
                    <span class="text-small font-bold">
                      {pref.replace(/[都道府県]$/, "")}
                    </span>
                    <span class="text-[0.65rem] font-normal text-[var(--color-primary)]">
                      {count}
                    </span>
                  </span>
                </button>
              );
            })}
          </div>
        </div>
      ))
    }
  </div>
</section>
