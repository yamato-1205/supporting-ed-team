---
import HeadingUnderline from "../HeadingUnderline.astro";
import {
  PLACES_PAGE,
  googleMapsEmbedUrl,
  googleMapsLink,
} from "../../data/places";
import type { Location } from "../../lib/microcms";
import houseImg from "../../assets/decorations/house.png";

interface Props {
  locations: Location[];
}

const { locations } = Astro.props;
const first = locations[0];
const initialSrc = first
  ? googleMapsEmbedUrl(first.lat, first.lng, 12)
  : "https://maps.google.com/maps?q=日本&z=5&output=embed&hl=ja";
---

<section
  id="google-map"
  class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
>
  <HeadingUnderline class="mb-3 md:mb-4">{PLACES_PAGE.googleTitle}</HeadingUnderline>
  <p class="mx-auto mb-8 max-w-2xl text-center font-normal leading-relaxed text-black/75">
    {PLACES_PAGE.googleLead}
  </p>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] lg:items-start">
    <ul class="flex flex-col gap-2" role="list">
      {
        locations.map((loc, i) => (
          <li>
            <button
              type="button"
              class="place-map-pin group flex w-full items-center gap-3 rounded-xl border border-[var(--color-primary)]/20 bg-[var(--color-background)]/50 px-3 py-3 text-left transition-colors hover:border-[var(--color-primary)]/50 aria-[pressed=true]:border-[var(--color-primary)] aria-[pressed=true]:bg-[var(--color-primary)]/10"
              data-place-id={loc.id}
              data-lat={loc.lat}
              data-lng={loc.lng}
              data-name={loc.locationName}
              aria-pressed={i === 0 ? "true" : "false"}
            >
              <span class="relative inline-flex h-12 w-12 shrink-0 items-center justify-center">
                <img
                  src={houseImg.src}
                  alt=""
                  aria-hidden="true"
                  class="h-12 w-auto"
                />
              </span>
              <span class="min-w-0">
                <span class="block truncate font-bold leading-snug">
                  {loc.locationName}
                </span>
                <span class="mt-0.5 block truncate text-small font-normal text-black/60">
                  {(loc.prefectures ?? []).join("・")}
                </span>
              </span>
            </button>
          </li>
        ))
      }
    </ul>

    <div class="space-y-3">
      <div class="overflow-hidden rounded-2xl border border-[var(--color-primary)]/15 bg-[var(--color-background)]">
        <iframe
          id="place-google-embed"
          title="居場所のGoogleマップ"
          src={initialSrc}
          class="aspect-[4/3] w-full border-0 md:aspect-[16/11]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        />
      </div>
      {
        first && (
          <p class="text-center text-small font-normal text-black/60">
            <a
              id="place-google-external"
              href={googleMapsLink(first.lat, first.lng, first.locationName)}
              target="_blank"
              rel="noopener noreferrer"
              class="font-bold text-[var(--color-primary)] underline-offset-2 hover:underline"
            >
              Googleマップで開く
            </a>
          </p>
        )
      }
    </div>
  </div>
</section>
