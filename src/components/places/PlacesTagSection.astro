---
import HeadingUnderline from "../HeadingUnderline.astro";
import { PLACES_PAGE, countByTag } from "../../data/places";
import type { Location } from "../../lib/microcms";

interface Props {
  locations: Location[];
}

const { locations } = Astro.props;
const fields = countByTag(locations, "field");
const genres = countByTag(locations, "genre");
---

<section
  id="tag-search"
  class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
>
  <HeadingUnderline class="mb-3 md:mb-4">{PLACES_PAGE.tagTitle}</HeadingUnderline>
  <p class="mx-auto mb-8 max-w-2xl text-center font-normal leading-relaxed text-black/75">
    {PLACES_PAGE.tagLead}
  </p>

  {
    fields.size > 0 && (
      <div class="mb-6">
        <p class="mb-3 text-center text-small tracking-wide text-black/55">分野</p>
        <ul class="flex flex-wrap justify-center gap-2">
          {[...fields.entries()].map(([tag, count]) => (
            <li>
              <button
                type="button"
                class="place-tag-btn rounded-full border-2 border-[var(--color-primary)]/35 bg-[var(--color-background)] px-4 py-2 text-small font-bold transition-colors hover:border-[var(--color-primary)] aria-[pressed=true]:border-[var(--color-primary)] aria-[pressed=true]:bg-[var(--color-primary)] aria-[pressed=true]:text-white"
                data-tag={tag}
                aria-pressed="false"
              >
                {tag}
                <span class="ml-1 font-normal opacity-70">{count}</span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    genres.size > 0 && (
      <div>
        <p class="mb-3 text-center text-small tracking-wide text-black/55">関心・キーワード</p>
        <ul class="flex flex-wrap justify-center gap-2">
          {[...genres.entries()].map(([tag, count]) => (
            <li>
              <button
                type="button"
                class="place-tag-btn rounded-full border-2 border-[var(--color-primary)]/25 bg-white px-3.5 py-1.5 text-small font-bold transition-colors hover:border-[var(--color-primary)] aria-[pressed=true]:border-[var(--color-primary)] aria-[pressed=true]:bg-[var(--color-primary)] aria-[pressed=true]:text-white"
                data-tag={tag}
                aria-pressed="false"
              >
                {tag}
                <span class="ml-1 font-normal opacity-70">{count}</span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
    <button
      type="button"
      class="place-clear-btn text-small font-bold text-[var(--color-primary)] underline-offset-2 hover:underline"
      hidden
    >
      {PLACES_PAGE.clearFilter}
    </button>
  </div>
</section>
