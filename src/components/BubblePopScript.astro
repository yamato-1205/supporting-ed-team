---
/** サイト全体のボタンクリックでシャボン玉が割れる演出 */
---

<script>
  const POP_MS = 380;

  function spawnBurst(x: number, y: number) {
    const root = document.createElement("div");
    root.className = "bubble-burst";
    root.style.left = `${x}px`;
    root.style.top = `${y}px`;

    const ring = document.createElement("span");
    ring.className = "bubble-burst-ring";
    root.appendChild(ring);

    const count = 10;
    for (let i = 0; i < count; i++) {
      const p = document.createElement("span");
      p.className = "bubble-burst-particle";
      const angle = (Math.PI * 2 * i) / count + Math.random() * 0.35;
      const dist = 32 + Math.random() * 48;
      p.style.setProperty("--tx", `${Math.cos(angle) * dist}px`);
      p.style.setProperty("--ty", `${Math.sin(angle) * dist}px`);
      p.style.setProperty("--size", `${8 + Math.random() * 14}px`);
      root.appendChild(p);
    }

    document.body.appendChild(root);
    window.setTimeout(() => root.remove(), 600);
  }

  function navigate(btn: HTMLAnchorElement) {
    const href = btn.getAttribute("href");
    if (!href) return;

    const target = btn.getAttribute("target");
    if (target === "_blank") {
      window.open(href, "_blank", "noopener,noreferrer");
      btn.classList.remove("bubble-popping");
      delete btn.dataset.bubblePopping;
      return;
    }

    // 同一ページ内のアンカー（#contact / /#support など）はスムーズスクロール
    try {
      const url = new URL(href, window.location.href);
      const samePage =
        url.origin === window.location.origin &&
        url.pathname === window.location.pathname;
      if (samePage && url.hash) {
        const el = document.getElementById(url.hash.slice(1));
        if (el) el.scrollIntoView({ behavior: "smooth" });
        else window.location.hash = url.hash;
        btn.classList.remove("bubble-popping");
        delete btn.dataset.bubblePopping;
        return;
      }
    } catch {
      /* fall through */
    }

    window.location.href = href;
  }

  document.addEventListener(
    "click",
    (e) => {
      if (e.defaultPrevented) return;
      if (!(e instanceof MouseEvent) || e.button !== 0) return;
      if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

      const btn = (e.target as Element | null)?.closest?.(
        "a.btn-hover, a.balloon-float",
      ) as HTMLAnchorElement | null;
      if (!btn || btn.dataset.bubblePopping) return;
      if (!btn.getAttribute("href")) return;

      e.preventDefault();
      btn.dataset.bubblePopping = "1";
      btn.classList.add("bubble-popping");

      const rect = btn.getBoundingClientRect();
      spawnBurst(rect.left + rect.width / 2, rect.top + rect.height / 2);

      window.setTimeout(() => navigate(btn), POP_MS);
    },
    true,
  );
</script>
