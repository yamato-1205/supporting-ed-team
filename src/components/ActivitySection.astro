---
import SectionBubbles from "./SectionBubbles.astro";
import HeadingUnderline from "./HeadingUnderline.astro";
import MultilineText from "./MultilineText.astro";
import { ACTIVITY_ITEMS } from "../data/home";
---

<section
  id="activity"
  class="relative z-[1] overflow-x-clip bg-white py-7 md:py-10 lg:py-12"
>
  <SectionBubbles variant="activity" />

  <div class="section-container">
    <h2 class="heading-2 mb-10 md:mb-14">活動内容</h2>

    <div class="grid grid-cols-1 gap-16 md:grid-cols-2 md:gap-12 lg:gap-20">
      {
        ACTIVITY_ITEMS.map((item) => (
          <article>
            <div class="overflow-hidden rounded-lg mb-6">
              <img
                src={item.image.src}
                alt={item.alt}
                class="w-full aspect-[4/3] object-cover"
              />
            </div>

            <HeadingUnderline as="h3" level="3" class="mb-4">
              {item.title}
            </HeadingUnderline>

            <MultilineText text={item.body} />
          </article>
        ))
      }
    </div>
  </div>
</section>
