---
import HeadingUnderline from "./HeadingUnderline.astro";

interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section
  id={id}
  class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
>
  <HeadingUnderline class="mb-6 md:mb-8">{title}</HeadingUnderline>
  <div class="mx-auto max-w-2xl space-y-4">
    <slot />
  </div>
</section>
