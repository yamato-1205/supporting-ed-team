---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section
  id={id}
  class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
>
  <h2 class="heading-2 text-center mb-2">{title}</h2>
  <hr
    class="mx-auto mb-6 md:mb-8 w-28 md:w-32 border-0 border-t-2"
    style="border-color: var(--color-primary);"
  />
  <div class="space-y-4 max-w-2xl mx-auto">
    <slot />
  </div>
</section>
