---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section
  id={id}
  class="bg-white rounded-2xl md:rounded-3xl px-6 py-8 md:px-10 md:py-10"
>
  <div class="mb-6 flex justify-center md:mb-8">
    <div class="inline-flex flex-col items-center">
      <h2 class="heading-2 text-center">{title}</h2>
      <hr
        class="w-[calc(100%+2em)] border-0 border-t-[4px]"
        style="border-color: var(--color-primary);"
      />
    </div>
  </div>
  <div class="mx-auto max-w-2xl space-y-4">
    <slot />
  </div>
</section>
