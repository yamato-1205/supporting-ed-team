---
import { HERO } from "../data/home";
---

<section
  id="hero"
  class="relative overflow-hidden h-screen bg-no-repeat bg-top bg-center [background-size:auto_100%]"
  style={`background-image: url('${HERO.bubblesImg.src}');`}
>
  <!-- ── スマホ: 縦並び（雲中央→横書きテキスト下） ── -->
  <div
    class="sm:hidden absolute inset-0 flex flex-col items-center justify-center gap-4 z-10 px-6"
  >
    <img
      src={HERO.cloudImg.src}
      alt={HERO.cloudAlt}
      class="pointer-events-none select-none w-[85vw] h-auto object-contain block"
    />
    <div
      class="heading-3 bg-white rounded-xl px-5 py-4 w-full max-w-[400px]"
      style="line-height: 2.0; color: var(--color-primary);"
    >
      {
        HERO.lines.map((line, i) => (
          <>
            {i > 0 && <br />}
            {line}
          </>
        ))
      }
    </div>
  </div>

  <!-- ── PC(sm+): 雲の中心＝画面中心、テキストは雲右端から絶対配置 ── -->
  <div class="hidden sm:block absolute inset-0 z-10">
    <img
      src={HERO.cloudImg.src}
      alt={HERO.cloudAlt}
      class="pointer-events-none select-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[65vw] h-auto object-contain"
    />
    <div
      class="heading-3 absolute top-1/2 -translate-y-1/2 flex flex-row-reverse bg-white rounded-xl"
      style="left: calc(50% + 32.5vw + 0.5rem); line-height: 2.8; letter-spacing: 0.12em; color: var(--color-primary); padding-top: 20px; padding-bottom: 20px;"
    >
      {
        HERO.verticalColumns.map((column) => (
          <p style="writing-mode: vertical-rl; margin: 0;">{column}</p>
        ))
      }
    </div>
  </div>
</section>
