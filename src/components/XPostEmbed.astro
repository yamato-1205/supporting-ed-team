---
import { fetchXEmbed } from "../lib/socialEmbed";
import { SNS_URLS } from "../data/sns";

interface Props {
  postUrl: string;
}

const { postUrl } = Astro.props;
const embed = await fetchXEmbed(postUrl);
const profileUrl = SNS_URLS.footer.x!;
---

<div class="w-full max-w-sm mx-auto">
  {
    embed ? (
      <Fragment set:html={embed.html} />
    ) : (
      <a
        href={profileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center h-40 rounded-2xl border border-gray-200 bg-white text-sm hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] transition-colors"
      >
        Xで最新の投稿を見る ↗
      </a>
    )
  }
</div>

<script
  async
  src="https://platform.twitter.com/widgets.js"
  charset="utf-8"></script>
