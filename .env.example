# ============================================================
# 環境変数（このファイルをコピーして .env を作成）
#   cp .env.example .env
# ============================================================

# --- 秘密情報（Git にコミットしない） ---

# microCMS API キー（管理画面 > API設定 > APIキー）
MICROCMS_API_KEY=your_api_key_here

# --- 以下もすべて必須（未設定だとビルド失敗） ---

# microCMS のサービスドメイン（https://{domain}.microcms.io）
MICROCMS_SERVICE_DOMAIN=sapochimu

# Google Apps Script お問い合わせフォームの Web アプリ URL
PUBLIC_CONTACT_FORM_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Syncable 寄付フォーム URL
PUBLIC_DONATE_URL=https://syncable.biz/associate/sapochimu1/donate

# お問い合わせメール（フッター表示・mailto・フォーム placeholder）
PUBLIC_CONTACT_EMAIL=sapochimu1103@gmail.com

# note アカウント名（RSS 取得・「もっと見る」リンク）
PUBLIC_NOTE_ACCOUNT=sapochimu

# サイトの正規 URL（OG 画像・canonical・sitemap 用。末尾スラッシュなし）
PUBLIC_SITE_URL=https://supporting-ed-team.pages.dev
